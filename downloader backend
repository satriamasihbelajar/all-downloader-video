const API_BASE = "https://backend-downloader-production.up.railway.app";

async function downloadVideo(inputUrl) {
  const res = await fetch(`${API_BASE}/download?url=${encodeURIComponent(inputUrl)}`);
  const data = await res.json();

  if (!data.video) {
    alert("Gagal ambil video");
    return;
  }

  // buka video
  window.open(data.video, "_blank");
}
